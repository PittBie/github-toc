{
  "name": "github-wiki-toc",
  "version": "0.1.0",
  "description": "Obsidian plugin that generates a Table of Contents for GitHub wiki-style vaults",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "obsidian-plugin", "toc", "github-wiki"],
  "author": "Pitt Biebach",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0"
  }
}
